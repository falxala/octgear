{
  "name": "octgear-remapper",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "pnpm --filter @octgear/web dev",
    "build": "pnpm --filter @octgear/web build",
    "firmware:build": "scripts/compile-firmware.sh",
    "firmware:web": "scripts/build-web-firmware.sh",
    "hardware:generate": "node scripts/generate-hardware-config.mjs",
    "rescue-cmd:assets": "scripts/build-rescue-cmd-asset.sh",
    "preview": "pnpm --filter @octgear/web preview",
    "typecheck": "pnpm --filter @octgear/web typecheck"
  }
}
