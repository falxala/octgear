@echo off
pushd "%~dp0" >nul 2>&1
powershell -NoProfile -ExecutionPolicy Bypass -Command "function SendCmd($serial,$cmd){$bytes=[Text.Encoding]::ASCII.GetBytes($cmd + [char]10); $serial.Write($bytes,0,$bytes.Length)}; function Drain($serial,$ms){$deadline=(Get-Date).AddMilliseconds($ms); $lines=@(); while((Get-Date) -lt $deadline){try{$line=$serial.ReadLine(); $lines+=$line; Write-Host $line}catch{Start-Sleep -Milliseconds 40}}; return $lines}; $ports=@([System.IO.Ports.SerialPort]::GetPortNames()|Sort-Object); if($ports.Count -eq 0){Write-Host 'No COM ports found'; pause; exit}; $port=$null; $devices=@(Get-CimInstance Win32_PnPEntity | Where-Object { $_.Name -match '\(COM[0-9]+\)' }); foreach($device in $devices){if($device.PNPDeviceID -match 'VID_CAFE.*PID_C608' -or $device.PNPDeviceID -match 'VID_239A.*PID_CAFE' -or $device.Name -match 'Cyborg'){if($device.Name -match '\((COM[0-9]+)\)'){$port=$Matches[1]; Write-Host ('Detected {0}: {1}' -f $port,$device.Name); break}}}; if(-not $port){foreach($candidate in $ports){$candidateDevice=$null; foreach($device in $devices){if($device.Name -match ('\('+$candidate+'\)')){$candidateDevice=$device; break}}; if($candidateDevice -and $candidateDevice.PNPDeviceID -notmatch '^USB\\'){Write-Host ('Skipping {0}: {1}' -f $candidate,$candidateDevice.Name); continue}; Write-Host ('Checking {0}...' -f $candidate); try{$p=New-Object System.IO.Ports.SerialPort($candidate,115200,'None',8,'One'); $p.NewLine=[string][char]10; $p.ReadTimeout=80; $p.WriteTimeout=350; $p.DtrEnable=$true; $p.RtsEnable=$true; $p.Open(); Start-Sleep -Milliseconds 1500; SendCmd $p 'probe'; Start-Sleep -Milliseconds 250; SendCmd $p 'probe'; $deadline=(Get-Date).AddMilliseconds(1800); $lines=@(); while((Get-Date) -lt $deadline){try{$line=$p.ReadLine(); $lines+=$line; if($line -match 'CYBORG8 ACK'){$port=$candidate; break}}catch{Start-Sleep -Milliseconds 40}}; if($lines.Count -gt 0){Write-Host (($lines|Select-Object -Last 3) -join ' | ')}; $p.Close(); if($port){break}}catch{Write-Host ('  skip: {0}' -f $_.Exception.Message); if($p -and $p.IsOpen){$p.Close()}}}}; if(-not $port){Write-Host 'Auto-detect failed. Select a COM port.'; for($i=0;$i -lt $ports.Count;$i++){$name=''; $id=''; foreach($device in $devices){if($device.Name -match ('\('+$ports[$i]+'\)')){$name=$device.Name; $id=$device.PNPDeviceID; break}}; if($name){Write-Host ('[{0}] {1} - {2}' -f ($i+1),$ports[$i],$name); Write-Host ('    {0}' -f $id)}else{Write-Host ('[{0}] {1}' -f ($i+1),$ports[$i])}}; $n=[int](Read-Host 'Port number'); $port=$ports[$n-1]}; $s=New-Object System.IO.Ports.SerialPort($port,115200,'None',8,'One'); $s.NewLine=[string][char]10; $s.ReadTimeout=120; $s.WriteTimeout=500; $s.DtrEnable=$true; $s.RtsEnable=$true; $s.Open(); Write-Host ('Connected to {0}' -f $port); SendCmd $s 'probe'; $hello=Drain $s 1000; if(($hello -join ' ') -notmatch 'CYBORG8 ACK'){Write-Host 'No rescue ACK. Try pressing Enter once, or reconnect while holding Key 5.'}; Write-Host 'Type help or exit'; while($true){$cmd=Read-Host 'cyborg'; if($cmd -eq 'exit'){break}; SendCmd $s $cmd; Drain $s 1500 | Out-Null}; $s.Close()"
popd >nul 2>&1
